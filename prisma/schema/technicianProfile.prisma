model TechnicianProfile {
  id           String  @id @default(uuid())
  profilePhoto String?
  bio          String?
  experience   Int?

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]

  @@map("technicianProfiles")
}
